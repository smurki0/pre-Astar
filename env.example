# ===========================================
# ASTAR E-Commerce Platform Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Database Configuration
# PostgreSQL (Neon serverless). Use the POOLED connection string for the app.
# Keep sslmode=require. channel_binding=require is recommended by Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
#
# Deploy schema non-destructively with:  npx prisma migrate deploy   (or  prisma db push)
#   (never use `prisma migrate reset` in production - it wipes data).

# Authentication
# JWT secret for token signing (REQUIRED in production)
# Generate a strong random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Astar

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@astar.com

# Payment Gateway - Paymob (Egypt)
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_IFRAME_ID=your-iframe-id
PAYMOB_HMAC_SECRET=your-hmac-secret
PAYMOB_MERCHANT_PROFILE_ID=your-merchant-profile-id
PAYMOB_WEBHOOK_SECRET=your-webhook-secret
PAYMOB_ALLOWED_IPS="127.0.0.1,192.168.0.0/24,your-server-ip"
PAYMOB_DELIVERY_NEEDED=false

# Payment Gateway - Fawry (Egypt)
FAWRY_MERCHANT_CODE=your-merchant-code
FAWRY_SECURITY_KEY=your-security-key

# Payment Gateway - Stripe (International)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable

# Upload Configuration
# Image uploads use Vercel Blob in production (the serverless filesystem is
# read-only, so writing to public/uploads fails). Create a Blob store in your
# Vercel project (Storage -> Blob) and Vercel injects this token automatically.
# When it is NOT set (local dev) uploads fall back to ./public/uploads.
BLOB_READ_WRITE_TOKEN=
UPLOAD_DIR=./upload
MAX_FILE_SIZE=5242880

# Security
ENCRYPTION_KEY=your-32-character-encryption-key

# Admin Credentials (for seed data)
ADMIN_EMAIL=admin@astar.com
ADMIN_PASSWORD=admin123
